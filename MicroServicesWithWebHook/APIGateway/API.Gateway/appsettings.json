{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "product-route": {
        "ClusterId": "product-cluster",
        "Match": {
          /* Any URL request that starts with /product-service/ will hit this route */
          "Path": "product-service/{**catch-all}"
        },
        "Transforms": [
          /* Remove the /product-service prefix before forwarding the request to the downstream service */
          { "PathPattern": "{**catch-all}" }
        ]
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "order-service/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "product-cluster": {
        "Destinations": {
          "product-api-instance": {
            "Address": "https://localhost:7279/"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "order-api-instance": {            "Address": "https://localhost:7022"
          }
        }
      }
    }
  }
}
